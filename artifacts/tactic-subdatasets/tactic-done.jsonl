{"hash":"bb756e43d1a819d41d0a3ca0f32be2870f83067c","parent_hashes":["697c4671295c9e9196e976a95c566a6cb5193ba0"],"author":"Jason Gross","author_email":"jgross@mit.edu","date":"2022-04-18T10:48:12+01:00","message_subject":"Add more operations to parsing in the equivalence checker (#1197)","message_body":"We now support parsing `call`, `cmovb`, `cmp`, `db`, `dd`, `dq`, `dw`,\n`je`, `jmp`, `mul`, `pop`, `push`, `rcr`, and `shrx`, and prefixes like\n`rep ret`, `repz ret`, `repnz ret`.  We also support labels, `align`,\nand `default rel`.  We should probably try to properly support a larger\nfraction of https://www.nasm.us/xdoc/2.15.05/html/nasmdoc3.html at some\npoint.\n\nWe now parse instructions (opcodes) in a case-insensitive manner, though\nmany other places are still case-sensitive.\n\nThe stack is now computed based on push and pop instructions as well as\nthe adjustments to rsp, and supports aggregating multiple constant-sized\nadjustments to rsp.\n\nWe don't yet support the `0F3h` syntax alternative for the hex `0xF3`,\nmostly because I couldn't be bothered to write a parser for it right\nnow.","files_changed_count":13,"insertions":912,"deletions":113,"changed_files":["_CoqProject","src/Assembly/Equality.v","src/Assembly/Equivalence.v","src/Assembly/EquivalenceProofs.v","src/Assembly/Parse.v","src/Assembly/Parse/Examples/boringssl_nasm_full_mul_p256.v","src/Assembly/Parse/TestAsm.v","src/Assembly/Symbolic.v","src/Assembly/Syntax.v","src/Assembly/WithBedrock/Semantics.v","src/Assembly/WithBedrock/SymbolicProofs.v","src/CLI.v","src/Util/Strings/Parse/Common.v"],"coq_files_changed":["src/Assembly/Equality.v","src/Assembly/Equivalence.v","src/Assembly/EquivalenceProofs.v","src/Assembly/Parse.v","src/Assembly/Parse/Examples/boringssl_nasm_full_mul_p256.v","src/Assembly/Parse/TestAsm.v","src/Assembly/Symbolic.v","src/Assembly/Syntax.v","src/Assembly/WithBedrock/Semantics.v","src/Assembly/WithBedrock/SymbolicProofs.v","src/CLI.v","src/Util/Strings/Parse/Common.v"],"touches_proof_files":true,"commit_class":"proof_add","keywords":["try","case","right"],"class_confidence":"diff","diff_sorry_removed":false,"diff_net_proof_lines":798,"tactic_tags":["destruct","cbv","intros","subst","simpl","rewrite","repeat","try","exfalso","assumption","apply","left","right","intuition","first","fail","generalize","progress","intro","specialize","cbn","eauto","vm_compute","do","native_compute","exact","compute","done","econstructor","inversion","exists","idtac","enough","by","clear"],"proof_style":["mixed"]}
