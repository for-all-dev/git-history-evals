{"hash":"d1c94864a063f4616b92c2e5195eab92e14bac44","parent_hashes":["890de0520b9f7f91073c1522f68a2830c6c4b02f"],"author":"Jason Gross","author_email":"jgross@mit.edu","date":"2020-05-20T01:00:49-04:00","message_subject":"Better computation of loose bounds","message_body":"We now compute the loose bounds by recording the number of additions\nand/or balanced subtractions we want to be able to do in a row before we\nneed to multiply and carry.  Note that balanced subtraction always takes\na bit more overhead than addition.\n\nThis is a more conservative variant of #799 that doesn't actually change\nthe bounds, and makes the genuine change of #799 easier to see, namely,\nreducing `headspace_add_count` from `2` to `1`.","files_changed_count":5,"insertions":72,"deletions":45,"changed_files":["src/Bedrock/Tests/Proofs/X1305_32.v","src/Bedrock/Tests/Proofs/X25519_32.v","src/Bedrock/Tests/Proofs/X25519_64.v","src/PushButtonSynthesis/UnsaturatedSolinas.v","src/UnsaturatedSolinasHeuristics.v"],"coq_files_changed":["src/Bedrock/Tests/Proofs/X1305_32.v","src/Bedrock/Tests/Proofs/X25519_32.v","src/Bedrock/Tests/Proofs/X25519_64.v","src/PushButtonSynthesis/UnsaturatedSolinas.v","src/UnsaturatedSolinasHeuristics.v"],"touches_proof_files":true,"commit_class":"proof_add","keywords":["compute","by","do","change"],"class_confidence":"diff","diff_sorry_removed":false,"diff_net_proof_lines":27,"tactic_tags":["vm_compute","intro","cut","repeat","clear","revert","apply","cbv","easy","compute","have","enough","do","rewrite","cbn","split","intros","subst","etransitivity","case","nia"],"proof_style":["mixed"]}
