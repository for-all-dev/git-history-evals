{"hash":"593ac735ec3ac754d4f6b82d8d3fdf2f5bce9b6a","parent_hashes":["d23ac0f3abe5cc2ede8983d77b1a2f9c4b96b04e"],"author":"Jason Gross","author_email":"jgross@mit.edu","date":"2021-04-08T10:10:54-04:00","message_subject":"Pipe through an always-false equivalence checker","message_body":"This should be enough rope to check equivalence of PHOASTs with assembly\nexpressions.  It's plausible we want more control over the calling\nconventions from the command line, for example, specifying:\n- what to do when we run out of registers / how arguments are stored on\n  the stack\n- support for a number of common calling conventions\n\nWe may also want to emit better headers for the assembly files, rather\nthan replicating the header of the input file.","files_changed_count":12,"insertions":706,"deletions":144,"changed_files":["_CoqProject.in","src/Assembly/Equivalence.v","src/Assembly/Parse.v","src/BoundsPipeline.v","src/CLI.v","src/PushButtonSynthesis/BarrettReduction.v","src/PushButtonSynthesis/BaseConversion.v","src/PushButtonSynthesis/FancyMontgomeryReduction.v","src/PushButtonSynthesis/Primitives.v","src/PushButtonSynthesis/SaturatedSolinas.v","src/PushButtonSynthesis/UnsaturatedSolinas.v","src/PushButtonSynthesis/WordByWordMontgomery.v"],"coq_files_changed":["src/Assembly/Equivalence.v","src/Assembly/Parse.v","src/BoundsPipeline.v","src/CLI.v","src/PushButtonSynthesis/BarrettReduction.v","src/PushButtonSynthesis/BaseConversion.v","src/PushButtonSynthesis/FancyMontgomeryReduction.v","src/PushButtonSynthesis/Primitives.v","src/PushButtonSynthesis/SaturatedSolinas.v","src/PushButtonSynthesis/UnsaturatedSolinas.v","src/PushButtonSynthesis/WordByWordMontgomery.v"],"touches_proof_files":true,"commit_class":"proof_add","keywords":["enough","example","do"],"class_confidence":"diff","diff_sorry_removed":false,"diff_net_proof_lines":561,"tactic_tags":["enough","set","absurd","right","refine","by","do","first","left"],"proof_style":["mixed"]}
{"hash":"93ef32c9aefc4a4837822876605d33646eb6555e","parent_hashes":["d6e41844944556282e3a3e53b4dad0caad85800b"],"author":"Dustin Jamner","author_email":"dijamner@me.com","date":"2020-12-29T16:24:03-05:00","message_subject":"Work on copy fn","message_body":"","files_changed_count":1,"insertions":991,"deletions":0,"changed_files":["src/Bedrock/Field/Synthesis/Generic/Copy.v"],"coq_files_changed":["src/Bedrock/Field/Synthesis/Generic/Copy.v"],"touches_proof_files":true,"commit_class":"proof_add","keywords":[],"class_confidence":"diff","diff_sorry_removed":false,"diff_net_proof_lines":991,"tactic_tags":["unfold","cbv","intros","delta","rewrite","repeat","cbn","first","apply","revert","do","induction","destruct","intro","simpl","auto","exists","split","clear","eapply","try","subst","inversion","eauto","exfalso","assert","exact","constructor","eexists","by","fail","elim","symmetry","case","generalize","replace","change","remember","tauto","absurd","pose","solve","idtac","progress"],"proof_style":["mixed"]}
{"hash":"87f6a00b9333cf1bb2054383909957dd6964ae91","parent_hashes":["e8755ef0c8827190d5b14dde2e5e33730ac92eb8"],"author":"Jason Gross","author_email":"jgross@mit.edu","date":"2020-05-05T21:44:07-04:00","message_subject":"Add support for comments and stripping annotations","message_body":"After `Import Crypto.Language.PreExtra`, it's now possible to do `dlet _\n:= ident.comment stuff in ...` and have `stuff` appear in the\nsynthesized code as a comment.  There's room for improvement with\nregards to quoting and handling multi-line comments, but it works for\ndebugging purposes.\n\nNote that bounds analysis does not add casts underneath comments, though\nI believe let-lifting still happens, and the comments are still\ndefinitely subject to rewriting.\n\nIf you want comments whose variable dependencies are eliminated during\nthe very last dead-code-elimination phase of the stringification\npipeline, use `ident.comment_no_keep`.  Both `ident.comment` and\n`ident.comment_no_keep` have type `forall {A}, A -> unit`.\n\nThere are now also passes `StripAnnotations` and `StripAllAnnotations`;\nthe former takes an expression and input bounds, and strips cast\nannotations which are guaranteed to be no-ops given the bounds; it's\nproven to preserve `Wf` and `Interp`-relatedness.  The\n`StripAllAnnotations` pass strips *all* cast annotations, even the ones\nthat might be doing necessary truncation or modulo computations, and\ndoes not require input bounds.  It's proven to preserve `Wf` but has no\n`Interp` proofs.","files_changed_count":21,"insertions":754,"deletions":137,"changed_files":["src/AbstractInterpretation/AbstractInterpretation.v","src/AbstractInterpretation/Proofs.v","src/AbstractInterpretation/Wf.v","src/AbstractInterpretation/WfExtra.v","src/AbstractInterpretation/ZRange.v","src/AbstractInterpretation/ZRangeProofs.v","src/BoundsPipeline.v","src/CompilersTestCases.v","src/Language/APINotations.v","src/Language/IdentifierParameters.v","src/Language/PreExtra.v","src/MiscCompilerPasses.v","src/MiscCompilerPassesProofs.v","src/MiscCompilerPassesProofsExtra.v","src/SlowPrimeSynthesisExamples.v","src/Stringification/C.v","src/Stringification/Go.v","src/Stringification/IR.v","src/Stringification/Java.v","src/Stringification/Language.v","src/Stringification/Rust.v"],"coq_files_changed":["src/AbstractInterpretation/AbstractInterpretation.v","src/AbstractInterpretation/Proofs.v","src/AbstractInterpretation/Wf.v","src/AbstractInterpretation/WfExtra.v","src/AbstractInterpretation/ZRange.v","src/AbstractInterpretation/ZRangeProofs.v","src/BoundsPipeline.v","src/CompilersTestCases.v","src/Language/APINotations.v","src/Language/IdentifierParameters.v","src/Language/PreExtra.v","src/MiscCompilerPasses.v","src/MiscCompilerPassesProofs.v","src/MiscCompilerPassesProofsExtra.v","src/SlowPrimeSynthesisExamples.v","src/Stringification/C.v","src/Stringification/Go.v","src/Stringification/IR.v","src/Stringification/Java.v","src/Stringification/Language.v","src/Stringification/Rust.v"],"touches_proof_files":true,"commit_class":"proof_add","keywords":["crypto","do","have"],"class_confidence":"diff","diff_sorry_removed":false,"diff_net_proof_lines":617,"tactic_tags":["reflect","revert","induction","intros","solve","apply","idtac","constructor","cbv","split","eapply","eauto","rewrite","by","try","repeat","progress","exfalso","assumption","clear","right","congruence","cbn","generalize","subst","discriminate","pose","destruct","refine","exact","vm_compute","lazy","assert","compute","set","absurd","iota"],"proof_style":["mixed"]}
